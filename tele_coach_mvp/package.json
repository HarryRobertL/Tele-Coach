{
  "name": "tele_coach_mvp",
  "version": "0.1.0",
  "private": true,
  "description": "Local desktop coaching MVP scaffold (Electron + React + TypeScript + Vite).",
  "main": "app/electron/dist/app/electron/main.js",
  "scripts": {
    "dev": "npm run free-port && npm run rebuild-native && npm run build:electron && concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config app/renderer/vite.config.ts",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electron app/electron/dist/app/electron/main.js",
    "free-port": "kill-port 5173 || true",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build --config app/renderer/vite.config.ts",
    "build:electron": "tsc -p app/electron/tsconfig.json",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "start": "electron app/electron/dist/app/electron/main.js",
    "typecheck": "tsc -p app/electron/tsconfig.json --noEmit && tsc -p app/renderer/tsconfig.json --noEmit",
    "dev:smoke": "tsx scripts/dev_smoke.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "electron": "^36.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "@electron/rebuild": "^3.7.1",
    "kill-port": "^2.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  }
}
