# Copy to .env in this directory if you use shell-level env injection.
# Most Tele Coach settings use config/feature_flags.json and Electron at runtime.

# Runtime environment label (development | pilot | production)
# TELE_COACH_ENV=development

# Dev: point Electron at Vite (npm run dev sets this automatically)
# VITE_DEV_SERVER_URL=http://localhost:5173

# Verbose speech-to-text logging to the main process console
# DEBUG_STT=1

# Verbose adaptive classifier logging
# DEBUG_ADAPTIVE=1

# Whisper delivery: pilot uses bundled/upstream policy; enterprise uses internal URLs
# TELE_COACH_WHISPER_DELIVERY_MODE=pilot

# Allow falling back to enterprise ZIP URLs when upstream binary is unavailable (pilot)
# TELE_COACH_WHISPER_ALLOW_UPSTREAM_FALLBACK=true

# Enterprise model (see config/whisper_delivery.json)
# TELE_COACH_WHISPER_MODEL_URL_ENTERPRISE=
# TELE_COACH_WHISPER_MODEL_SHA256_ENTERPRISE=

# Enterprise Whisper binaries per platform (see config/whisper_delivery.json)
# TELE_COACH_WHISPER_BINARY_URL_DARWIN_ARM64=
# TELE_COACH_WHISPER_BINARY_ZIP_SHA256_DARWIN_ARM64=
# TELE_COACH_WHISPER_BINARY_URL_DARWIN_X64=
# TELE_COACH_WHISPER_BINARY_ZIP_SHA256_DARWIN_X64=
# TELE_COACH_WHISPER_BINARY_URL_WIN32_X64=
# TELE_COACH_WHISPER_BINARY_ZIP_SHA256_WIN32_X64=

# Packaging helpers
# PREPACK_PLATFORM=mac
# PREPACK_ARCH=arm64
